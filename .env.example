# OpenAI-compatible local server settings
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=local-model

# Orchestrator settings
AGENT_WORKSPACE_ROOT=.
AGENT_SYSTEM_DNA=system_dna.md
AGENT_MAX_TOOL_STEPS=4

# Multimodal defaults (optional)
AGENT_ENABLE_CAMERA=false
AGENT_ENABLE_AUDIO=false
AGENT_MULTIMODAL_INTERVAL=3
AGENT_MULTIMODAL_ITERATIONS=1
AGENT_ENABLE_TRANSCRIPTION=true
AGENT_TRANSCRIPTION_MODEL=base
AGENT_TRANSCRIPTION_COMPUTE_TYPE=int8
AGENT_TRANSCRIPTION_DEVICE=auto

# Secure daemon auth
AGENT_DAEMON_TOKEN=

# Connector credentials (used only when connector consent is granted)
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=
NOTION_API_TOKEN=
NOTION_DATABASE_ID=
TODOIST_API_TOKEN=
