{
  "projectName": "cognitive-twin-agent",
  "mode": "review-before-commit",
  "policyPaths": {
    "modelRouting": "policies/model-routing.policy.json",
    "memoryGovernance": "policies/memory-governance.policy.json",
    "multideviceTrustSync": "policies/multidevice-trust-sync.policy.json"
  },
  "modelRouting": {
    "default": {
      "provider": "ollama",
      "model": "qwen3:14b",
      "endpoint": "http://localhost:11434"
    },
    "fastFallback": {
      "provider": "ollama",
      "model": "qwen3:8b",
      "endpoint": "http://localhost:11434"
    },
    "deepReasoningFallback": {
      "provider": "ollama",
      "model": "deepseek-r1-distill-qwen-14b",
      "endpoint": "http://localhost:11434",
      "enabled": true
    }
  },
  "memory": {
    "vectorStore": "local",
    "embeddingModel": "nomic-embed-text",
    "sources": [
      "code",
      "architecture",
      "ux-principles",
      "writing-style"
    ]
  },
  "guardrails": {
    "requireCritiquePass": true,
    "enforceLocalFirst": true,
    "maxCloudDependencyIntroductions": 0,
    "verbosityPolicy": "concise-technical"
  },
  "multimodal": {
    "enabled": false,
    "camera": {
      "enabled": false,
      "deviceIndex": 0
    },
    "audio": {
      "enabled": false,
      "sampleSeconds": 2,
      "sampleRate": 16000,
      "enableTranscription": true,
      "transcriptionModel": "base",
      "transcriptionComputeType": "int8",
      "transcriptionDevice": "auto",
      "modelCacheDir": "memory/models"
    },
    "actions": {
      "proposeSafeAction": true,
      "requireApprovalBeforeExecution": true
    },
    "connectors": {
      "googleCalendar": {
        "enabled": true,
        "requiresConsent": true
      },
      "notion": {
        "enabled": true,
        "requiresConsent": true
      },
      "todoist": {
        "enabled": true,
        "requiresConsent": true
      }
    },
    "privacy": {
      "requireExplicitConsent": true,
      "storeRawMedia": false,
      "rawMediaRetentionHours": 0,
      "storeOnlySummaries": true
    }
  }
}
